{
  "$id": "https://github.com/data-fair/catalog-azure-synapse/catalog-config",
  "x-exports": ["types", "validate", "schema"],
  "title": "AzureSynapseConfig",
  "type": "object",
  "additionalProperties": false,
  "required": ["account", "fileSystemName", "connectionMethod"],
  "properties": {
    "account": {
      "type": "string",
      "title": "Account",
      "x-i18n-title": {
        "fr": "Compte"
      },
      "description": "This corresponds to the name shown in the URL: https://<account>.dfs.core.windows.net",
      "x-i18n-description": {
        "fr": "Correspond au nom indiqué dans l'URL : https://<compte>.dfs.core.windows.net"
      }
    },
    "fileSystemName": {
      "type": "string",
      "title": "File system name",
      "x-i18n-title": {
        "fr": "Nom du système de fichiers"
      }
    },
    "connectionMethod": {
      "type": "object",
      "title": "Connection method",
      "x-i18n-title": {
        "fr": "Mode de connexion"
      },
      "description": "The connection method to use (Storage shared key, Secret client)",
      "x-i18n-description": {
        "fr": "Le mode de connexion à utiliser (Clé partagée de stockage, Client secret)"
      },
      "oneOfLayout": {
        "label": "Choose a connection method",
        "x-i18n-label": {
          "fr": "Choisir un mode de connexion"
        }
      },
      "oneOf": [
        {
          "title": "Storage shared key",
          "x-i18n-title": {
            "fr": "Clé partagée de stockage"
          },
          "required": ["accountKey"],
          "properties": {
            "key": {
              "const": "storageSharedKey"
            },
            "accountKey": {
              "type": "string",
              "title": "Account key",
              "x-i18n-title": {
                "fr": "Clé du compte"
              }
            }
          }
        },
        {
          "title": "Client secret",
          "required": ["tenantId", "clientId", "clientSecret"],
          "properties": {
            "key": {
              "const": "clientSecret"
            },
            "tenantId": {
              "type": "string",
              "title": "Tenant Id",
              "x-i18n-title": {
                "fr": "Identifiant de l'organisation"
              }
            },
            "clientId": {
              "type": "string",
              "title": "Client Id",
              "x-i18n-title": {
                "fr": "Identifiant du client"
              }
            },
            "clientSecret": {
              "type": "string",
              "title": "Client secret",
              "x-i18n-title": {
                "fr": "Clé secrète du client"
              }
            }
          }
        }
      ]
    }
  }
}
